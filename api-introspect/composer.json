{
    "name": "opnsense-sdk/api-introspect",
    "description": "Standalone OPNsense API inventory generator via runtime reflection against the opnsense submodule.",
    "type": "project",
    "license": "BSD-2-Clause",
    "require": {
        "php": ">=8.1",
        "ext-ctype": "*",
        "ext-dom": "*",
        "ext-filter": "*",
        "ext-json": "*",
        "ext-libxml": "*",
        "ext-simplexml": "*",
        "nikic/php-parser": "^5.7"
    },
    "autoload": {
        "psr-4": {
            "OpnsenseApiIntrospect\\": "src/"
        }
    },
    "bin": [
        "introspect.php",
        "verify-contract.php"
    ],
    "config": {
        "sort-packages": true
    }
}
